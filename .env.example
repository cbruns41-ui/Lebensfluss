# ─── Frontend (lokal: als .env.local kopieren) ────────────────────────────────

# PocketBase-URL – leer = nur lokaler Modus (News/Support im Browser)
# Server speichert NUR: Abo-Lizenzen, Support-Tickets, News – keine App-Inhalte
# Produktion:  https://api.deine-domain.de
# Lokal:      /pb  (nutzt Vite-Proxy → localhost:8090)
VITE_POCKETBASE_URL=

# Öffentliche App-URL
VITE_APP_URL=http://localhost:5173

# Stripe Checkout aktivieren (Server muss STRIPE_SECRET_KEY haben)
VITE_STRIPE_ENABLED=false

# ─── Vercel (Produktion): siehe deploy/vercel.env.example ─────────────────────
# Variablen in Vercel Dashboard setzen – nicht ins Repo committen.

# ─── Hetzner API-Server: siehe deploy/env.example ───────────────────────────
# Mit Vercel-Frontend: docker compose --env-file deploy/.env -f deploy/docker-compose.api.yml up -d
# Alles auf einem Server: docker compose --env-file deploy/.env -f deploy/docker-compose.yml up -d