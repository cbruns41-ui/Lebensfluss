# deploy/.env – auf dem Hetzner-Server als deploy/.env speichern

# Domains (für Caddy + Let's Encrypt)
APP_DOMAIN=lebensfluss.de
API_DOMAIN=api.lebensfluss.de

# Öffentliche App-URL (Stripe Redirects + CORS für Vercel-Frontend)
# Muss exakt der Vercel-URL entsprechen (mit https, ohne Slash am Ende)
APP_URL=https://lebensfluss.de

# Absender für Support-Mails (PocketBase Hook)
PB_SUPPORT_FROM=noreply@lebensfluss.de

# ─── Stripe (Dashboard → Developers) ─────────────────────────────────────────
# Secret Key (sk_live_… oder sk_test_…)
STRIPE_SECRET_KEY=sk_test_...
# Webhook Signing Secret (whsec_…) – Endpoint: https://api.DEINE-DOMAIN.de/api/lebensfluss/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Price-IDs aus Stripe Dashboard → Products
STRIPE_PRICE_LIFETIME=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ─── Setup ───────────────────────────────────────────────────────────────────
# 1. https://api.DEINE-DOMAIN.de/_/  → PocketBase Admin anlegen
# 2. Settings → Mail → SMTP konfigurieren
# 3. Collections importieren: pocketbase/pb_schema.json
# 4. Users-Collection: Feld "role" (select: user, admin)
# 5. Admin-User: gleiche E-Mail wie App-Admin, role=admin
# 6. site_config: key=default, supportEmails=["deine@email.de"]
# 7. Stripe Webhook-Events: checkout.session.completed, customer.subscription.updated,
#    customer.subscription.deleted, invoice.paid
# 8. Vercel: deploy/vercel.env.example → Environment Variables
# 9. Hetzner API: docker compose --env-file deploy/.env -f deploy/docker-compose.api.yml up -d
#    (oder alles auf einem Server: deploy/docker-compose.yml)