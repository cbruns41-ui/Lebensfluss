# In Vercel → Project → Settings → Environment Variables eintragen
# (für Production, Preview und Development jeweils setzen)

# PocketBase-API (Hetzner)
VITE_POCKETBASE_URL=https://api.lebensfluss.de

# Öffentliche Frontend-URL (Stripe-Redirects, Links)
VITE_APP_URL=https://lebensfluss.de

# Stripe Checkout aktivieren (PocketBase braucht STRIPE_SECRET_KEY)
VITE_STRIPE_ENABLED=true